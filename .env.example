# ===========================================
# Roboroça - Environment Variables
# ===========================================
# Copie este arquivo para .env e preencha os valores

# -----------------
# Ambiente
# -----------------
ENVIRONMENT=development
DEBUG=true

# -----------------
# Segurança
# -----------------
# Gere uma chave secreta segura: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=sua-chave-secreta-aqui-mude-em-producao

# -----------------
# Banco de Dados
# -----------------
# Para desenvolvimento local (SQLite):
DATABASE_URL=sqlite+aiosqlite:///./roboroca.db
# Para produção (PostgreSQL):
# DATABASE_URL=postgresql+asyncpg://roboroca:roboroca123@localhost:5432/roboroca

# -----------------
# DigitalOcean Spaces (S3-compatible)
# -----------------
DO_SPACES_KEY=
DO_SPACES_SECRET=
DO_SPACES_BUCKET=roboroca
DO_SPACES_REGION=nyc3
DO_SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com

# -----------------
# Frontend
# -----------------
# URL do frontend (para CORS em producao e links em emails)
FRONTEND_URL=http://localhost:3000
# URL da API para o frontend (build-time para Next.js)
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# -----------------
# Upload
# -----------------
MAX_UPLOAD_SIZE=524288000
UPLOAD_DIR=./uploads

# -----------------
# Machine Learning
# -----------------
ML_MODELS_DIR=./ml_models

# -----------------
# Docker / PostgreSQL (para docker-compose)
# -----------------
POSTGRES_USER=roboroca
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=roboroca

# -----------------
# Dominio e SSL (producao)
# -----------------
# DOMAIN=roboroca.com.br
# CERTBOT_EMAIL=admin@roboroca.com.br

# -----------------
# CORS (producao — separar por virgula ou JSON array)
# -----------------
# CORS_ORIGINS=https://roboroca.com.br,https://aerial.roboroca.com.br,https://calc.roboroca.com.br,https://precision.roboroca.com.br,https://equipment.roboroca.com.br,https://spectral.roboroca.com.br

# -----------------
# Redis (JWT blacklist, cache, rate limiting)
# -----------------
REDIS_URL=redis://localhost:6379/0

# -----------------
# Email / SMTP
# -----------------
# Exemplo com Gmail: SMTP_HOST=smtp.gmail.com, SMTP_PORT=587, SMTP_USE_TLS=true
# Exemplo com Zoho:  SMTP_HOST=smtp.zoho.com, SMTP_PORT=587
# Exemplo com Resend: SMTP_HOST=smtp.resend.com, SMTP_PORT=465, SMTP_USE_TLS=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@roboroca.com.br
SMTP_FROM_NAME=Roboroca
SMTP_USE_TLS=true

# -----------------
# Resend API (email async - alternativa ao SMTP)
# -----------------
# Obtenha sua chave em https://resend.com
RESEND_API_KEY=

# -----------------
# Sentinel Hub (NDVI via satelite - opcional)
# -----------------
# Registre-se em https://dataspace.copernicus.eu
SENTINEL_CLIENT_ID=
SENTINEL_CLIENT_SECRET=
